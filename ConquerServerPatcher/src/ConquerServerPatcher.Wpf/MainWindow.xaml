<Window x:Class="ConquerRsaTool.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Conquer Server Patcher"
        Icon="Logo.ico"
        Width="1040" Height="900"
        MinWidth="960" MinHeight="850"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        StateChanged="Window_StateChanged"
        AutomationProperties.Name="Conquer Server Patcher"
        KeyboardNavigation.TabNavigation="Continue">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="44"
                      ResizeBorderThickness="6"
                      CornerRadius="12"
                      GlassFrameThickness="0"
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Border x:Name="RootBorder"
            Background="{StaticResource PageBrush}"
            BorderBrush="#C7D0DF"
            BorderThickness="1"
            CornerRadius="12"
            ClipToBounds="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="150"/>
            </Grid.RowDefinitions>

            <Border Background="#15213A" CornerRadius="11,11,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="44"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Margin="16,0,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Image Source="Logo.ico" Width="26" Height="26"
                                   Stretch="Uniform"
                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                            <TextBlock Text="CONQUER SERVER PATCHER" Foreground="#D5DEF0"
                                       FontSize="12" FontWeight="SemiBold"
                                       VerticalAlignment="Center" Margin="9,0,0,0"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal"
                                    WindowChrome.IsHitTestVisibleInChrome="True">
                            <Button Content="&#xE921;" Style="{StaticResource TitleBarButtonStyle}"
                                    AutomationProperties.Name="Minimize"
                                    Click="MinimizeWindow_Click"/>
                            <Button x:Name="MaximizeWindowButton"
                                    Content="&#xE922;" Style="{StaticResource TitleBarButtonStyle}"
                                    AutomationProperties.Name="Maximize"
                                    Click="MaximizeWindow_Click"/>
                            <Button Content="&#xE8BB;" Style="{StaticResource CloseTitleBarButtonStyle}"
                                    AutomationProperties.Name="Close"
                                    Click="CloseWindow_Click"/>
                        </StackPanel>
                    </Grid>

                    <StackPanel Grid.Row="1" Margin="30,13,30,22">
                        <TextBlock Text="Use your Custom Server.dat"
                                   Foreground="White" FontSize="28" FontWeight="Bold"/>
                        <TextBlock Text="Prepare your client with a permanent key through a simple, safe workflow."
                                   Foreground="#C7D2E8" FontSize="14" Margin="0,5,0,0"/>
                        <Border Background="#263A60" CornerRadius="10"
                                Padding="10,4" Margin="0,10,0,0"
                                HorizontalAlignment="Left">
                            <TextBlock Text="SUPPORTED CLIENTS: PATCH 5095 - 6609"
                                       Foreground="#DCE7FF" FontSize="11"
                                       FontWeight="SemiBold"/>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="26,24"
                            MaxWidth="1200"
                            HorizontalAlignment="Center">
                    <Border Style="{StaticResource CardStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Margin="0,0,28,0">
                                <TextBlock Text="QUICK PATCH" Foreground="{StaticResource AccentBrush}"
                                           FontSize="12" FontWeight="Bold"/>
                                <TextBlock Text="Choose the client and apply the patch"
                                           FontSize="23" FontWeight="SemiBold" Margin="0,5,0,6"/>
                                <TextBlock Text="First we verify the executable. Then you can review its new name and create a patched copy without changing the original."
                                           Foreground="{StaticResource MutedTextBrush}" FontSize="14"
                                           TextWrapping="Wrap" MaxWidth="590"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal"
                                        VerticalAlignment="Center">
                                <Button x:Name="SelectClientButton"
                                        Content="1. _Choose client"
                                        Style="{StaticResource SecondaryButton}"
                                        Padding="18,14" FontSize="14" Margin="0,0,8,0"
                                        AutomationProperties.HelpText="Choose and verify a Conquer.exe file."
                                        Click="SelectClient_Click"/>
                                <Button x:Name="ApplyPatchButton"
                                        Content="2. _Apply patch"
                                        Padding="18,14" FontSize="14"
                                        IsEnabled="False"
                                        AutomationProperties.HelpText="Apply the permanent key and create the executable with the chosen name."
                                        Click="ApplyPatch_Click"/>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.ColumnSpan="2" Margin="0,20,0,0">
                                <Label Content="_Selected client" Target="{Binding ElementName=ExePath}"
                                       FontWeight="SemiBold" Padding="0" Margin="0,4,0,5"/>
                                <TextBox x:Name="ExePath" IsReadOnly="True"
                                         AutomationProperties.Name="Selected client path"
                                         ToolTip="Path to the selected Conquer.exe"/>
                                <TextBlock x:Name="ClientStatusText"
                                           Text="No client selected."
                                           Foreground="{StaticResource MutedTextBrush}"
                                           AutomationProperties.LiveSetting="Polite"
                                           Margin="1,6,0,0"/>

                                <Label Content="_Output name (optional)"
                                       Target="{Binding ElementName=OutputFileName}"
                                       FontWeight="SemiBold" Padding="0" Margin="0,14,0,5"/>
                                <TextBox x:Name="OutputFileName"
                                         AutomationProperties.Name="Output executable name"
                                         AutomationProperties.HelpText="Leave empty to append Patched to the original name. The exe extension is optional."
                                         ToolTip="Example: MyConquer.exe. Leave empty to use ConquerPatched.exe."/>
                                <TextBlock Text="The suggested name is &lt;name&gt;Patched.exe. You may change it or omit the .exe extension."
                                           Foreground="{StaticResource MutedTextBrush}"
                                           FontSize="12" Margin="1,5,0,0"/>
                                <CheckBox x:Name="BypassPlayExe"
                                          Content="_Allow direct launch without play.exe"
                                          IsChecked="True" Margin="1,11,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border x:Name="ResultPanel" Style="{StaticResource CardStyle}"
                            Background="#EAF8F2" BorderBrush="#A8DDC9"
                            Margin="0,14,0,0" Visibility="Collapsed">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Width="38" Height="38" CornerRadius="19" Background="#16845B">
                                <TextBlock Text="&#x2713;" Foreground="White" FontSize="22"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="1" Margin="14,0">
                                <TextBlock Text="Client ready" FontWeight="Bold" FontSize="16"/>
                                <TextBlock x:Name="ResultText" Foreground="#386A58"
                                           TextWrapping="Wrap" Margin="0,3,0,0"/>
                            </StackPanel>
                            <Button Grid.Column="2" Content="Open folder"
                                    Style="{StaticResource SecondaryButton}"
                                    Click="OpenOutputFolder_Click"/>
                        </Grid>
                    </Border>

                    <Grid Margin="0,14,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="14"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Server key" FontSize="18" FontWeight="SemiBold"/>
                                <TextBlock x:Name="KeyStatusText" Text="Checking..."
                                           Foreground="{StaticResource MutedTextBrush}"
                                           TextWrapping="Wrap" Margin="0,7,0,12"/>
                                <TextBlock Text="Stored in your Windows profile and reused automatically."
                                           Foreground="{StaticResource MutedTextBrush}"
                                           TextWrapping="Wrap" FontSize="13"/>
                                <Button Content="Open key folder"
                                        Style="{StaticResource SecondaryButton}"
                                        HorizontalAlignment="Left" Margin="0,16,0,0"
                                        Click="OpenKeysFolder_Click"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="DAT files" FontSize="18" FontWeight="SemiBold"/>
                                <TextBlock Text="Decrypt with the client's original key and encrypt with the new server key."
                                           Foreground="{StaticResource MutedTextBrush}"
                                           TextWrapping="Wrap" Margin="0,7,0,14"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Button Content="_Decrypt DAT" Click="DecryptDat_Click"/>
                                    <Button Grid.Column="2" Content="_Encrypt DAT"
                                            Style="{StaticResource SecondaryButton}"
                                            Click="EncryptDat_Click"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Border Style="{StaticResource CardStyle}" Margin="0,14,0,0" Padding="18">
                        <Expander Header="Advanced tools">
                            <StackPanel Margin="0,14,0,0">
                                <TextBlock Text="Diagnostic tools for the selected client."
                                           Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,10"/>
                                <WrapPanel>
                                    <Button Content="_Analyze client"
                                            Style="{StaticResource SecondaryButton}"
                                            Margin="0,0,8,0" Click="Analyze_Click"/>
                                    <Button Content="_Extract original key"
                                            Style="{StaticResource SecondaryButton}"
                                            Click="ExtractKey_Click"/>
                                </WrapPanel>
                            </StackPanel>
                        </Expander>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <Border Grid.Row="2" Background="#101827" Padding="22,12"
                    CornerRadius="0,0,11,11">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Activity" Foreground="#DCE5F5" FontWeight="SemiBold"/>
                    <TextBox Grid.Row="1" x:Name="LogBox" IsReadOnly="True"
                             AutomationProperties.Name="Activity log"
                             Background="Transparent" BorderThickness="0"
                             Foreground="#B9C7DC" Padding="0,7,0,0"
                             FontFamily="Consolas" FontSize="12"
                             TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                             AcceptsReturn="True"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
