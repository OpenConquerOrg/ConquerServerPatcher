<Application x:Class="ConquerRsaTool.Wpf.App" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" StartupUri="MainWindow.xaml">
<Application.Resources>
<SolidColorBrush x:Key="Accent" Color="#5965F2"/><SolidColorBrush x:Key="Panel" Color="#171A24"/><SolidColorBrush x:Key="Panel2" Color="#202432"/>
<Style TargetType="Window"><Setter Property="Background" Value="#0F1118"/><Setter Property="Foreground" Value="#F4F5FA"/><Setter Property="FontFamily" Value="Segoe UI"/></Style>
<Style TargetType="Button"><Setter Property="Padding" Value="14,8"/><Setter Property="Margin" Value="4"/><Setter Property="Background" Value="{StaticResource Accent}"/><Setter Property="Foreground" Value="White"/><Setter Property="BorderThickness" Value="0"/><Setter Property="Cursor" Value="Hand"/></Style>
<Style TargetType="TextBox"><Setter Property="Padding" Value="8"/><Setter Property="Margin" Value="4"/><Setter Property="Background" Value="{StaticResource Panel2}"/><Setter Property="Foreground" Value="White"/><Setter Property="BorderBrush" Value="#34394D"/></Style>
<Style TargetType="CheckBox"><Setter Property="Margin" Value="8"/></Style>
<Style TargetType="GroupBox"><Setter Property="Margin" Value="8"/><Setter Property="Padding" Value="8"/><Setter Property="BorderBrush" Value="#34394D"/></Style>
</Application.Resources></Application>
