<Window x:Class="ConquerRsaTool.Wpf.MainWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="Conquer RSA Tool" Width="1040" Height="760" MinWidth="880" MinHeight="640" WindowStartupLocation="CenterScreen">
<Grid Margin="18"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition/><RowDefinition Height="190"/></Grid.RowDefinitions>
<StackPanel><TextBlock Text="Conquer RSA Tool" FontSize="30" FontWeight="Bold"/><TextBlock Text="Extrae claves, cifra/descifra DAT y parchea clientes Conquer 2.0" Foreground="#AEB4C6" Margin="0,4,0,14"/></StackPanel>
<TabControl Grid.Row="1" Background="{StaticResource Panel}" BorderBrush="#34394D">
<TabItem Header="Cliente"><ScrollViewer><StackPanel Margin="12"><GroupBox Header="Conquer.exe"><Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBox x:Name="ExePath"/><Button Grid.Column="1" Content="Examinar" Click="BrowseExe_Click"/></Grid></GroupBox><WrapPanel><Button Content="Analizar cliente" Click="Analyze_Click"/><Button Content="Extraer clave pública" Click="ExtractKey_Click"/></WrapPanel><GroupBox Header="Parchear cliente"><StackPanel><Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBox x:Name="PatchPublicKeyPath"/><Button Grid.Column="1" Content="Clave pública" Click="BrowsePatchPublicKey_Click"/></Grid><Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBox x:Name="PatchedExeOutput"/><Button Grid.Column="1" Content="Destino" Click="BrowsePatchedOutput_Click"/></Grid><CheckBox x:Name="BypassPlayExe" Content="Permitir ejecutar directamente sin play.exe" IsChecked="True"/><Button Content="Parchear cliente" HorizontalAlignment="Left" Click="PatchClient_Click"/></StackPanel></GroupBox></StackPanel></ScrollViewer></TabItem>
<TabItem Header="Claves"><StackPanel Margin="12"><GroupBox Header="Generar RSA 2048"><StackPanel><Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBox x:Name="PublicKeyOutput" Text="keys/public_key.pem"/><Button Grid.Column="1" Content="Destino pública" Click="BrowsePublicOutput_Click"/></Grid><Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBox x:Name="PrivateKeyOutput" Text="keys/private_key.pem"/><Button Grid.Column="1" Content="Destino privada" Click="BrowsePrivateOutput_Click"/></Grid><Button Content="Generar par de claves" HorizontalAlignment="Left" Click="GenerateKeys_Click"/></StackPanel></GroupBox></StackPanel></TabItem>
<TabItem Header="Archivos DAT"><ScrollViewer><StackPanel Margin="12"><GroupBox Header="Descifrar"><StackPanel><Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBox x:Name="DecryptInput"/><Button Grid.Column="1" Content="Archivo cifrado" Click="BrowseDecryptInput_Click"/></Grid><Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBox x:Name="DecryptPublicKey"/><Button Grid.Column="1" Content="Clave pública" Click="BrowseDecryptKey_Click"/></Grid><Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBox x:Name="DecryptOutput"/><Button Grid.Column="1" Content="Destino" Click="BrowseDecryptOutput_Click"/></Grid><Button Content="Descifrar DAT" HorizontalAlignment="Left" Click="Decrypt_Click"/></StackPanel></GroupBox><GroupBox Header="Cifrar"><StackPanel><Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBox x:Name="EncryptInput"/><Button Grid.Column="1" Content="Archivo plano" Click="BrowseEncryptInput_Click"/></Grid><Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBox x:Name="EncryptPrivateKey"/><Button Grid.Column="1" Content="Clave privada" Click="BrowseEncryptKey_Click"/></Grid><Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBox x:Name="EncryptOutput"/><Button Grid.Column="1" Content="Destino" Click="BrowseEncryptOutput_Click"/></Grid><Button Content="Cifrar DAT" HorizontalAlignment="Left" Click="Encrypt_Click"/></StackPanel></GroupBox></StackPanel></ScrollViewer></TabItem>
</TabControl>
<GroupBox Grid.Row="2" Header="Registro"><TextBox x:Name="LogBox" IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" AcceptsReturn="True"/></GroupBox>
</Grid></Window>
